    <!-- JS -->

    <script src="script.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            const API_BASE = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
                ? 'http://localhost:5000/api'
                : (window.location.origin.includes('vercel.app')
                    ? 'https://webcom-sirsa.onrender.com/api'
                    : window.location.origin + '/api');

            try {
                const res = await fetch(`${API_BASE}/data`);
                if (!res.ok) throw new Error('Network response was not ok');
                const data = await res.json();

                // TESTIMONIALS (RESULTS) SECTION
                const container = document.getElementById('testimonialsContainer');
                if (container && data.testimonials) {
                    container.innerHTML = '';
                    const testimonialsToShow = data.testimonials.slice(0, 6);
                    testimonialsToShow.forEach((test, index) => {
                        const student = test.student || 'Successful Student';
                        const score = test.score || 'Achiever';
                        const review = test.review || 'Excellent coaching and support.';
                        let mediaHtml = '';

                        let photoUrl = typeof resolveWebcomImageUrl === 'function' ? resolveWebcomImageUrl(test.photo) : test.photo;

                        if (photoUrl && !photoUrl.includes('placehold.co')) {
                            mediaHtml = `<img loading="lazy" src="${photoUrl}" alt="${student}" class="testimonial-photo mb-3">`;
                        } else {
                            let colorClass = 'score-gold';
                            if (score.includes('90') || score.includes('8') || score.includes('7.5')) colorClass = 'score-pink';
                            mediaHtml = `
                                <div class="score-placeholder-wrapper" style="height: 180px;">
                                    <div class="score-placeholder ${colorClass}">${score}</div>
                                </div>`;
                        }

                        const videoBtnHtml = test.videoUrl ? `<br><button class="btn btn-sm btn-outline-info mt-3 fw-bold play-video-btn" data-video="${test.videoUrl}"><i class="fa-solid fa-play me-2"></i>Watch Video</button>` : '';
                        
                        const testimonialHtml = `
                            <div class="col-md-4">
                                <div class="testimonial-card reveal reveal-delay-1 text-center">
                                    <div class="testimonial-badge">${score}</div>
                                    ${mediaHtml}
                                    <p class="mt-3">“${review}”</p>
                                    <h5 class="fw-bold">— ${student}</h5>
                                    ${videoBtnHtml}
                                </div>
                            </div>`;
                        container.insertAdjacentHTML('beforeend', testimonialHtml);
                        
                        const newElement = container.lastElementChild.querySelector('.reveal');
                        if (window.revealObserver && newElement) window.revealObserver.observe(newElement);
                    });

                    // Video Modal Triggers
                    document.querySelectorAll('.play-video-btn').forEach(btn => {
                        btn.addEventListener('click', (e) => {
                            let videoUrl = e.currentTarget.getAttribute('data-video');
                            if (videoUrl.includes('watch?v=')) videoUrl = videoUrl.replace('watch?v=', 'embed/');
                            const iframe = document.getElementById('videoIframe');
                            if (iframe) {
                                iframe.src = videoUrl;
                                new bootstrap.Modal(document.getElementById('videoModal')).show();
                            }
                        });
                    });
                }
            } catch (e) { 
                console.error("CMS Error:", e);
                // Fallback for testimonials if server is down
                const container = document.getElementById('testimonialsContainer');
                if (container && container.children.length === 0) {
                   // Optional: add static fallback cards here
                }
            }
        });

        // Reset video modal on close
        const videoModalEl = document.getElementById('videoModal');
        if (videoModalEl) {
            videoModalEl.addEventListener('hidden.bs.modal', () => {
                const iframe = document.getElementById('videoIframe');
                if (iframe) iframe.src = '';
            });
        }
    </script>

    <!-- VIDEO MODAL -->
    <div class="modal fade" id="videoModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content" style="background: transparent; border: none;">
                <div class="modal-header border-0 pb-0 justify-content-end">
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                        aria-label="Close"></button>
                </div>
                <div class="modal-body p-0 rounded overflow-hidden shadow-lg" style="background: #000;">
                    <div class="ratio ratio-16x9">
                        <iframe id="videoIframe" src="" allowfullscreen
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"></iframe>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>
